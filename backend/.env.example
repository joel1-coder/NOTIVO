# Copy this to .env and fill in your values

# Server Configuration
PORT=5000

# Frontend URLs (CORS Whitelist)
# Set to your production frontend URL
CLIENT_URL=https://notivo-adminlog.vercel.app
# For development, the app also allows: http://localhost:5173, http://localhost:3000

MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE?appName=App

JWT_SECRET=replace_with_a_strong_random_secret

EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
